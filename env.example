# OpenAI Compatible LLM Configuration
# Base URL for the LLM API (e.g., http://127.0.0.1:1234)
LLM_BASE_URL=http://127.0.0.1:1234

# oMdel name to use (e.g., gpt-3.5-turbo, gpt-4)
LLM_MODEL=gpt-3.5-turbo

# API token/key for authentication
LLM_API_KEY=http://127.0.0.1:1234

# Optional: Temperature parameter (0.0 to 2.0, default: 1.0)
LLM_TEMPERATURE=0.7

# Optional: Maximum tokens in response
LLM_MAX_TOKENS=1000
